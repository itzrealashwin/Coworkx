generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

// ── System / Auth ──
enum Role {
  user
  admin
  superadmin
}

enum Provider {
  local
  google
}

enum OtpType {
  verify
  reset
  admin_login
  email_verify
}

// ── Org & Project ──
enum OrgMemberRole {
  owner
  admin
  member
}

enum InvitationStatus {
  pending
  accepted
  expired
}

enum ProjectState {
  active
  archived
}

// ── Issues ──
enum IssueType {
  task
  bug
  sub_task
}

enum IssuePriority {
  low
  medium
  high
  critical
}

enum StatusCategory {
  todo
  in_progress
  done
}

enum IssueLinkType {
  blocks
  blocked_by
  relates_to
  duplicates
}

// ── Sprints ──
enum SprintStatus {
  planned
  active
  completed
}

// ── GitHub ──
enum GitHubAccountType {
  Organization
  User
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth & Users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String  @id @default(uuid())
  email       String  @unique @db.VarChar(255)
  username    String  @unique @db.VarChar(50)

  // Profile
  displayName String? @db.VarChar(100)
  avatarUrl   String?
  bio         String?
  timezone    String? @default("UTC")
  locale      String? @default("en")

  // Status
  isActive    Boolean   @default(true)
  isVerified  Boolean   @default(false)   // email verified
  isBot       Boolean   @default(false)

  // Timestamps
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?                   // soft delete

  // ── Relations ──
  credential              UserCredential?
  oauthProviders          UserOAuthProvider[]
  sessions                UserSession[]
  otps                    OtpVerification[]

  ownedOrgs               Organization[]          @relation("OrgOwner")
  orgMemberships          OrgMember[]             @relation("OrgMemberUser")
  orgMembersInvited       OrgMember[]             @relation("OrgMemberInviter")
  orgMembersRemoved       OrgMember[]             @relation("OrgMemberRemover")
  sentInvitations         OrgInvitation[]

  ledProjects             Project[]               @relation("ProjectLead")
  createdProjects         Project[]               @relation("ProjectCreator")
  projectMemberships      ProjectMember[]         @relation("ProjectMemberUser")
  projectMembersAdded     ProjectMember[]         @relation("ProjectMemberAdder")
  projectMembersRemoved   ProjectMember[]         @relation("ProjectMemberRemover")

  sprintsCreated          Sprint[]
  assignedIssues          Issue[]                 @relation("IssueAssignee")
  reportedIssues          Issue[]                 @relation("IssueReporter")
  issueLinksCreated       IssueLink[]
  issueComments           IssueComment[]
  issueHistoryEntries     IssueHistory[]
  linkedRepos             GitHubLinkedRepo[]

  receivedNotifications   Notification[]          @relation("NotificationRecipient")
  triggeredNotifications  Notification[]          @relation("NotificationActor")
  notificationPreferences NotificationPreference[]

  @@map("users")
  userOAuthTokens UserOAuthToken[]
}
// Dedicated credentials table for users who sign up with a password
model UserCredential {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  failedLoginAttempts Int      @default(0)

lockUntil           DateTime? 
  passwordChangedAt   DateTime?

  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("user_credentials")
}

model UserOAuthProvider {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String   @db.VarChar(50)
  providerUserId    String   @db.VarChar(255)
  providerEmail     String?  @db.VarChar(255)
  providerUsername  String?  @db.VarChar(100)
  providerAvatarUrl String?
  isPrimary         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@map("user_oauth_providers")
}

model UserOAuthToken {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    @db.VarChar(50)
  accessToken  String
  refreshToken String?
  scope        String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@map("user_oauth_tokens")
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  @@map("user_sessions")
}

// Merged: existing Otp model + otp_verifications from DBML
model OtpVerification {
  id         String   @id @default(uuid())
  
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  otpHash    String   @map("otp_hash")
  purpose    OtpType  @map("purpose")

  expiresAt  DateTime @map("expires_at")
  attempts   Int      @default(0)

  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId], map: "idx_otp_user_id")
  @@map("otp_verifications")
}


// ─────────────────────────────────────────────────────────────────────────────
// Organizations
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(100)
  logoUrl     String?
  description String?
  ownerId     String
  owner       User      @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members             OrgMember[]
  invitations         OrgInvitation[]
  roles               OrgRole[]
  projects            Project[]
  githubInstallations GitHubInstallation[]
  notifications       Notification[]
  notificationPrefs   NotificationPreference[]

  @@index([slug], name: "idx_org_slug")
  @@index([ownerId], name: "idx_org_owner_id")
  @@map("organizations")
}

model OrgInvitation {
  id         String           @id @default(uuid())
  orgId      String
  org        Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy  String
  inviter    User             @relation(fields: [invitedBy], references: [id]) // no delete action
  email      String           @db.VarChar(255)
  role       OrgMemberRole    @default(member)
  token      String           @unique
  status     InvitationStatus @default(pending)
  expiresAt  DateTime         @default(dbgenerated("now() + interval '7 days'"))
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())

  @@unique([orgId, email])
  @@index([token], name: "idx_invitations_token")
  @@index([orgId], name: "idx_invitations_org_id")
  @@map("org_invitations")
}

// Custom, workspace-scoped roles with JSONB permissions (RBAC)
// isSystem = true locks Owner/Admin from deletion
model OrgRole {
  id          String       @id @default(uuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String       @db.VarChar(50)
  description String?
  isSystem    Boolean      @default(false)
  permissions Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectMembers ProjectMember[]

  @@unique([orgId, name])
  @@index([orgId], name: "idx_roles_org_id")
  @@map("roles")
}

model OrgMember {
  id        String        @id @default(uuid())
  orgId     String
  org       Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation("OrgMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  role      OrgMemberRole @default(member)
  invitedBy String?
  inviter   User?         @relation("OrgMemberInviter", fields: [invitedBy], references: [id])
  joinedAt  DateTime      @default(now())
  removedAt DateTime?
  removedBy String?
  remover   User?         @relation("OrgMemberRemover", fields: [removedBy], references: [id])

  @@unique([orgId, userId])
  @@map("org_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// Projects
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id          String       @id @default(uuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String       @db.VarChar(255)
  slug        String       @db.VarChar(100) // URL: app.com/{org_slug}/{project_slug}
  key         String       @db.VarChar(10)  // Issue prefix e.g. CWX, BACK
  description String?
  icon        String?      // emoji or icon URL
  leadId      String?
  lead        User?        @relation("ProjectLead", fields: [leadId], references: [id])
  status      ProjectState @default(active)
  createdBy   String
  creator     User         @relation("ProjectCreator", fields: [createdBy], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  members      ProjectMember[]
  sprints      Sprint[]
  statuses     IssueStatus[]
  issues       Issue[]
  linkedRepos  GitHubLinkedRepo[]

  @@unique([orgId, key])
  @@unique([orgId, slug])
  @@index([orgId], name: "idx_projects_org_id")
  @@index([leadId], name: "idx_projects_lead_id")
  @@map("projects")
}

model ProjectMember {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation("ProjectMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  roleId    String    // custom project role from org roles table
  role      OrgRole   @relation(fields: [roleId], references: [id])
  addedBy   String?
  adder     User?     @relation("ProjectMemberAdder", fields: [addedBy], references: [id])
  joinedAt  DateTime  @default(now())
  removedAt DateTime?
  removedBy String?
  remover   User?     @relation("ProjectMemberRemover", fields: [removedBy], references: [id])

  @@unique([projectId, userId])
  @@index([projectId], name: "idx_project_members_project_id")
  @@index([userId], name: "idx_project_members_user_id")
  @@map("project_members")
}

model Sprint {
  id          String       @id @default(uuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String       @db.VarChar(255) // e.g. Sprint 1, Sprint 2
  goal        String?
  status      SprintStatus @default(planned)
  startDate   DateTime?
  endDate     DateTime?
  completedAt DateTime?
  createdBy   String
  creator     User         @relation(fields: [createdBy], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  issues Issue[]

  @@index([projectId], name: "idx_sprints_project_id")
  @@map("sprints")
}

// Kanban columns per project (Todo, In Progress, Done, or custom)
model IssueStatus {
  id        String         @id @default(uuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String         @db.VarChar(50)
  category  StatusCategory
  color     String         @default("#6B7280") @db.VarChar(7) // hex color for kanban column
  position  Int            // column order in kanban board
  createdAt DateTime       @default(now())

  issues Issue[]

  @@unique([projectId, name])
  @@index([projectId], name: "idx_project_statuses_project_id")
  @@map("project_statuses")
}

// ─────────────────────────────────────────────────────────────────────────────
// Issues
// ─────────────────────────────────────────────────────────────────────────────

model Issue {
  id          String      @id @default(uuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId    String?     // NULL = backlog
  sprint      Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  parentId    String?     // NULL = top-level; set = sub-task
  parent      Issue?      @relation("IssueSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Issue[]     @relation("IssueSubtasks")
  statusId    String
  status      IssueStatus @relation(fields: [statusId], references: [id])
  repoId      String?     // linked GitHub repository
  repo        GitHubLinkedRepo? @relation(fields: [repoId], references: [id], onDelete: SetNull)

  number      Int                // project issue sequence: CWX-1, CWX-2
  title       String             @db.VarChar(500)
  description String?
  type        IssueType
  priority    IssuePriority      @default(medium)

  assigneeId  String?
  assignee    User?    @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporterId  String
  reporter    User     @relation("IssueReporter", fields: [reporterId], references: [id])

  dueDate     DateTime? @db.Date
  startedAt   DateTime?
  completedAt DateTime?

  // GitHub sync fields
  isImported        Boolean  @default(false)
  githubIssueId     BigInt?  @unique // NULL = native issue
  githubIssueNumber Int?
  githubIssueUrl    String?
  githubSyncedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sourceLinks IssueLink[]    @relation("IssueLinkSource")
  targetLinks IssueLink[]    @relation("IssueLinkTarget")
  comments    IssueComment[]
  history     IssueHistory[]

  @@unique([projectId, number])
  @@index([projectId], name: "idx_issues_project_id")
  @@index([sprintId], name: "idx_issues_sprint_id")
  @@index([parentId], name: "idx_issues_parent_id")
  @@index([assigneeId], name: "idx_issues_assignee_id")
  @@index([statusId], name: "idx_issues_status_id")
  @@map("issues")
}

model IssueLink {
  id            String        @id @default(uuid())
  sourceIssueId String
  sourceIssue   Issue         @relation("IssueLinkSource", fields: [sourceIssueId], references: [id], onDelete: Cascade)
  targetIssueId String
  targetIssue   Issue         @relation("IssueLinkTarget", fields: [targetIssueId], references: [id], onDelete: Cascade)
  linkType      IssueLinkType
  createdBy     String?
  creator       User?         @relation(fields: [createdBy], references: [id])
  createdAt     DateTime      @default(now())

  @@unique([sourceIssueId, targetIssueId, linkType])
  @@index([sourceIssueId], name: "idx_issue_links_source")
  @@index([targetIssueId], name: "idx_issue_links_target")
  @@map("issue_links")
}

model IssueComment {
  id        String         @id @default(uuid())
  issueId   String
  issue     Issue          @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  parentId  String?        // threaded reply
  parent    IssueComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   IssueComment[] @relation("CommentReplies")
  content   String
  isEdited  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  @@index([issueId], name: "idx_comments_issue_id")
  @@index([parentId], name: "idx_comments_parent_id")
  @@map("issue_comments")
}

model IssueHistory {
  id        String   @id @default(uuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  changedBy String
  changer   User     @relation(fields: [changedBy], references: [id])
  field     String   @db.VarChar(50) // status | assignee | priority | sprint | title
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([issueId])
  @@map("issue_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// GitHub Integration
// ─────────────────────────────────────────────────────────────────────────────

model GitHubInstallation {
  id             String            @id @default(uuid())
  orgId          String
  org            Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  installationId BigInt            @unique // GitHub App installation ID
  accountLogin   String            @db.VarChar(100)
  accountType    GitHubAccountType
  accessToken    String?           // short-lived installation token
  tokenExpiresAt DateTime?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  linkedRepos GitHubLinkedRepo[]

  @@index([orgId], name: "idx_github_installations_org_id")
  @@map("github_installations")
}

model GitHubLinkedRepo {
  id             String             @id @default(uuid())
  projectId      String
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  installationId String
  installation   GitHubInstallation @relation(fields: [installationId], references: [id])
  githubRepoId   BigInt             // GitHub repository ID
  repoFullName   String             @db.VarChar(255) // owner/repo-name
  defaultBranch  String             @default("main") @db.VarChar(100)
  linkedBy       String?
  linker         User?              @relation(fields: [linkedBy], references: [id])
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())

  issues Issue[]

  @@unique([projectId, githubRepoId])
  @@index([projectId], name: "idx_github_linked_repos_project_id")
  @@map("github_linked_repos")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id           String       @id @default(uuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recipientId  String
  recipient    User         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId      String?      // NULL = system-generated
  actor        User?        @relation("NotificationActor", fields: [actorId], references: [id])
  type         String       @db.VarChar(50)  // notification event type
  resourceType String?      @db.VarChar(30)  // issue | sprint | invitation
  resourceId   String?
  title        String
  body         String?
  url          String?      // deep link to resource
  isRead       Boolean      @default(false)
  readAt       DateTime?
  createdAt    DateTime     @default(now())

  @@index([recipientId])
  @@index([recipientId, isRead])
  @@index([orgId])
  @@map("notifications")
}

model NotificationPreference {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  preferences Json         @default("{}") // per-event notification settings
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, orgId])
  @@map("notification_preferences")
}
